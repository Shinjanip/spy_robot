# ============================================================
# /etc/systemd/system/spyrobot-controller.service
#
# Auto-starts the motor/MQTT controller on boot.
# Install:
#   sudo cp spyrobot-controller.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable spyrobot-controller
#   sudo systemctl start spyrobot-controller
# ============================================================
[Unit]
Description=SpyRobot Motor and MQTT Controller
After=network-online.target
Wants=network-online.target
# Start after stream service so camera is available
After=spyrobot-stream.service

[Service]
Type=simple
User=pi
Group=gpio
EnvironmentFile=/etc/spyrobot/.env
WorkingDirectory=/home/pi/spyrobot/robot
ExecStart=/home/pi/spyrobot/venv/bin/python src/robot_controller.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=spyrobot-controller

# Watchdog: systemd restarts service if it stops responding
WatchdogSec=60

# Security
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/log /tmp

[Install]
WantedBy=multi-user.target


# ============================================================
