# ============================================================
# SpyRobot Raspberry Pi — Environment Configuration
# Copy to /etc/spyrobot/.env and restrict permissions:
#   sudo chmod 600 /etc/spyrobot/.env
# ============================================================

# HiveMQ Cloud MQTT
MQTT_HOST=YOUR_CLUSTER.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=robot_user
MQTT_PASS=YOUR_STRONG_PASSWORD

# MediaMTX server (laptop IP during dev, VPS IP in prod)
MEDIAMTX_HOST=192.168.1.100
MEDIAMTX_PORT=8554
STREAM_PATH=spyrobot/live

# Stream quality
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=30
STREAM_BITRATE=2000000

# Log level
LOG_LEVEL=INFO
