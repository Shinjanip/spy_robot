# ============================================================
# SpyRobot Raspberry Pi — Environment Configuration
# Copy to /etc/spyrobot/.env and restrict permissions:
#   sudo chmod 600 /etc/spyrobot/.env
# ============================================================

# HiveMQ Cloud MQTT
MQTT_HOST=5b5d1fc229d14745991d15a955fef7ca.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=spyrobot
MQTT_PASS=MySecurePass123

# MediaMTX server (laptop IP during dev, VPS IP in prod)
MEDIAMTX_HOST=10.243.216.9
MEDIAMTX_PORT=8554
STREAM_PATH=spyrobot/live

# Stream quality
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=30
STREAM_BITRATE=2000000

# Log level
LOG_LEVEL=INFO
